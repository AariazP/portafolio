        "NAME": "Jos\u00e9 Alejandro Arias",
        "DESCRIPCION_1": "\u7cfb\u7edf\u5de5\u7a0b\u5e08\uff0c\u4e13\u6ce8\u4e8e AWS \u4e91\u67b6\u6784\u548c\u53ef\u6269\u5c55\u7684\u6570\u636e\u9a71\u52a8\u89e3\u51b3\u65b9\u6848\u3002\u5728\u4f7f\u7528 S3\u3001Glue\u3001Lambda\u3001API Gateway \u548c Snowflake \u7684\u4e8b\u4ef6\u9a71\u52a8\u67b6\u6784\u65b9\u9762\u7ecf\u9a8c\u4e30\u5bcc\u3002\u6301\u6709 Linux Essentials \u548c Git Essential \u8ba4\u8bc1\u3002",
        "DESCRIPCION_2": "\u5728\u4f7f\u7528 Java\u3001Spring Boot\u3001JavaFX\u3001Angular \u548c TypeScript \u8fdb\u884c\u8f6f\u4ef6\u5f00\u53d1\u548c\u7cfb\u7edf\u96c6\u6210\u65b9\u9762\u5177\u6709\u4e30\u5bcc\u7684\u4e13\u4e1a\u77e5\u8bc6\u3002\u719f\u7ec3\u638c\u63e1\u4f7f\u7528 Kubernetes \u548c Docker \u7684\u5bb9\u5668\u7f16\u6392\u3001CI/CD \u7ba1\u9053\u548c\u57fa\u7840\u8bbe\u65bd\u5373\u4ee3\u7801\u3002",
        "DESCRIPCION_3": "\u719f\u6089\u654f\u6377\u65b9\u6cd5\u8bba\uff08Scrum\u3001Kanban\uff09\u548c DevOps \u5b9e\u8df5\uff0c\u5305\u62ec\u6301\u7eed\u96c6\u6210\u548c\u6301\u7eed\u4ea4\u4ed8\u3002\u4e86\u89e3 COBIT 2019\u3001TDD \u548c MDD\uff08Model Driven Development\uff09\u3002\u719f\u7ec3\u4f7f\u7528 Asana \u548c Confluence \u7b49\u9879\u76ee\u7ba1\u7406\u5de5\u5177\u3002",
